{
  "expo": {
    "name": "Conduit & Wire Pro",
    "slug": "conduit-wire-pro",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "conduitwirepro",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.illwired.conduitwirepro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "buildNumber": "6"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.illwired.conduitwirepro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "69075779-f2c6-4405-8d74-31e374618264"
      }
    },
    "owner": "illectric"
  }
}
